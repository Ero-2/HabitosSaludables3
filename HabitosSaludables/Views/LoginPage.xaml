<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="220,*">

        <!-- Header compacto con blobs -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#e4ecff" Offset="0.0"/>
                    <GradientStop Color="#ede8ff" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Blobs -->
            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="180"
                     HeightRequest="180"
                     Fill="#80c0ccff"
                     Margin="0,-50,-40,0"/>

            <Ellipse HorizontalOptions="Start"
                     VerticalOptions="End"
                     WidthRequest="90"
                     HeightRequest="90"
                     Fill="#66d4c8ff"
                     Margin="30,0,0,30"/>

            <VerticalStackLayout VerticalOptions="End"
                                 Padding="26,0,26,28"
                                 Spacing="8">

                <!-- Botón regresar glass -->
                <Border BackgroundColor="#80ffffff"
                        StrokeThickness="1"
                        Stroke="#80d0d8f0"
                        WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="Start"
                        Margin="0,0,0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Label Text="‹"
                           FontSize="20"
                           TextColor="#4a5a7a"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="¡Hola de nuevo!"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#1a2040"/>

                <Label Text="Ingresa a tu cuenta para continuar"
                       FontSize="12"
                       TextColor="#6a7a9a"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Formulario con card glass -->
        <ScrollView Grid.Row="1" BackgroundColor="#f0f4f8">
            <VerticalStackLayout Padding="20,20,20,40" Spacing="14">

                <Border BackgroundColor="#CCffffff"
                        StrokeThickness="1"
                        Stroke="#80dce8f4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,24" Spacing="16">

                        <!-- Campo correo -->
                        <VerticalStackLayout Spacing="7">
                            <Label Text="CORREO ELECTRÓNICO"
                                   FontSize="10"
                                   TextColor="#9ab0c8"
                                   CharacterSpacing="1.5"
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="#80f4f8fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdae8"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Entry x:Name="emailEntry"
                                       Placeholder="tu@correo.com"
                                       Keyboard="Email"
                                       Text="{Binding Email}"
                                       PlaceholderColor="#b8ccd8"
                                       TextColor="#1a2040"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="6,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Campo contraseña -->
                        <VerticalStackLayout Spacing="7">
                            <Label Text="CONTRASEÑA"
                                   FontSize="10"
                                   TextColor="#9ab0c8"
                                   CharacterSpacing="1.5"
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="#80f4f8fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdae8"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Entry x:Name="contrasenaEntry"
                                       Placeholder="••••••••"
                                       IsPassword="True"
                                       Text="{Binding Contrasena}"
                                       PlaceholderColor="#b8ccd8"
                                       TextColor="#1a2040"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="6,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <Label Text="¿Olvidaste tu contraseña?"
                               FontSize="12"
                               TextColor="#7a9ab8"
                               HorizontalTextAlignment="End"/>

                        <Button Text="Ingresar"
                                x:Name="LoginBtn"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#1a2040"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                HeightRequest="52"
                                Margin="0,4,0,0"/>

                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="10"
                                               Margin="0,4">
                            <BoxView BackgroundColor="#dde8f0"
                                     HeightRequest="1"
                                     WidthRequest="50"
                                     VerticalOptions="Center"/>
                            <Label Text="o"
                                   FontSize="11"
                                   TextColor="#b8ccd8"
                                   VerticalOptions="Center"/>
                            <BoxView BackgroundColor="#dde8f0"
                                     HeightRequest="1"
                                     WidthRequest="50"
                                     VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="RegistroBtn"
                               FontSize="13"
                               HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="¿No tienes cuenta? " TextColor="#9ab0c8" FontSize="13"/>
                                    <Span Text="Regístrate" TextColor="#1a2040" FontSize="13" FontAttributes="Bold"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterClicked"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
