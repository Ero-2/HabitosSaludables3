<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0e0e14">

    <Grid RowDefinitions="200,*">

        <!-- Header oscuro geométrico -->
        <Grid Grid.Row="0" BackgroundColor="#0e0e14" Padding="24,48,24,20">

            <!-- Círculo decorativo outline (esquina superior derecha) -->
            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="90"
                     HeightRequest="90"
                     Stroke="#ff4a6b"
                     StrokeThickness="1.5"
                     Opacity="0.2"
                     Margin="0,8,8,0"/>

            <!-- Cuadrado rotado acento coral -->
            <BoxView BackgroundColor="#ff4a6b"
                     WidthRequest="44"
                     HeightRequest="44"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Opacity="0.06"
                     Rotation="45"
                     Margin="0,22,22,0"/>

            <VerticalStackLayout VerticalOptions="End" Spacing="6">

                <!-- Botón regresar -->
                <Border BackgroundColor="#1a1a26"
                        StrokeThickness="1"
                        Stroke="#2a2a3a"
                        WidthRequest="32"
                        HeightRequest="32"
                        HorizontalOptions="Start"
                        Margin="0,0,0,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="‹"
                           FontSize="18"
                           TextColor="#666680"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Título con acento de color -->
                <Label FontSize="30" LineHeight="1.1">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="¡Hola de " FontSize="30" FontAttributes="Bold" TextColor="White" FontFamily="Syne"/>
                            <Span Text="nuevo!" FontSize="30" FontAttributes="Bold" TextColor="#ff4a6b" FontFamily="Syne"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Label Text="Ingresa a tu cuenta"
                       FontSize="11"
                       TextColor="#555570"
                       CharacterSpacing="0.5"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Formulario oscuro -->
        <ScrollView Grid.Row="1" BackgroundColor="#0e0e14">
            <VerticalStackLayout Padding="24,8,24,32" Spacing="16">

                <!-- Campo correo -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="CORREO"
                           FontSize="10"
                           TextColor="#555570"
                           CharacterSpacing="1.5"
                           FontAttributes="Bold"/>
                    <Border BackgroundColor="#1a1a26"
                            StrokeThickness="1"
                            Stroke="#2a2a3a"
                            HeightRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Entry x:Name="emailEntry"
                               Placeholder="tu@correo.com"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               PlaceholderColor="#444455"
                               TextColor="#ccccdd"
                               FontSize="13"
                               BackgroundColor="Transparent"
                               Margin="4,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Campo contraseña -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="CONTRASEÑA"
                           FontSize="10"
                           TextColor="#555570"
                           CharacterSpacing="1.5"
                           FontAttributes="Bold"/>
                    <Border BackgroundColor="#1a1a26"
                            StrokeThickness="1"
                            Stroke="#2a2a3a"
                            HeightRequest="50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Entry x:Name="contrasenaEntry"
                               Placeholder="••••••••"
                               IsPassword="True"
                               Text="{Binding Contrasena}"
                               PlaceholderColor="#444455"
                               TextColor="#ccccdd"
                               FontSize="13"
                               BackgroundColor="Transparent"
                               Margin="4,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- ¿Olvidaste contraseña? -->
                <Label Text="¿Olvidaste tu contraseña?"
                       FontSize="11"
                       TextColor="#ff4a6b"
                       HorizontalTextAlignment="End"
                       Margin="0,-6,0,0"/>

                <!-- Botón Ingresar -->
                <Button Text="Ingresar"
                        x:Name="LoginBtn"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#ff4a6b"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="52"
                        Margin="0,6,0,0"/>

                <!-- Link registro -->
                <Label x:Name="RegistroBtn"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="¿No tienes cuenta? " TextColor="#555570" FontSize="12"/>
                            <Span Text="Regístrate" TextColor="#ff4a6b" FontSize="12" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterClicked"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
