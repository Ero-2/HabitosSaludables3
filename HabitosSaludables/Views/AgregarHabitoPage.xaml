<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.AgregarHabitoPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="Auto,*">

        <!-- Header compacto con blobs -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#ede8ff" Offset="0.0"/>
                    <GradientStop Color="#e4ecff" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="120"
                     HeightRequest="120"
                     Fill="#66c8c0ff"
                     Margin="0,-30,-20,0"/>

            <Ellipse HorizontalOptions="Start"
                     VerticalOptions="End"
                     WidthRequest="70"
                     HeightRequest="70"
                     Fill="#66c0c8ff"
                     Margin="40,0,0,10"/>

            <Grid Padding="22,54,22,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Botón regresar glass -->
                <Border Grid.Column="0"
                        BackgroundColor="#80ffffff"
                        StrokeThickness="1"
                        Stroke="#80d0d8f8"
                        WidthRequest="34"
                        HeightRequest="34"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Label Text="‹"
                           FontSize="20"
                           TextColor="#4a5a8a"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                    <Label Text="Nuevo Hábito"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1a2040"/>
                    <Label Text="Personaliza tu rutina diaria"
                           FontSize="11"
                           TextColor="#7a9ab8"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Formulario con card glass -->
        <ScrollView Grid.Row="1" BackgroundColor="#f0f4f8">
            <VerticalStackLayout Padding="18,20,18,40" Spacing="14">

                <Border BackgroundColor="#CCffffff"
                        StrokeThickness="1"
                        Stroke="#80dce8f8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,24" Spacing="18">

                        <!-- Nombre del hábito -->
                        <VerticalStackLayout Spacing="7">
                            <Label Text="NOMBRE DEL HÁBITO"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#9ab0cc"
                                   CharacterSpacing="1.5"/>
                            <Border BackgroundColor="#80f0f6fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdae8"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="Ej. Beber 2 litros de agua"
                                       Text="{Binding Nombre}"
                                       PlaceholderColor="#b8ccd8"
                                       TextColor="#1a2040"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="6,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Categoría -->
                        <VerticalStackLayout Spacing="7">
                            <Label Text="CATEGORÍA"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#9ab0cc"
                                   CharacterSpacing="1.5"/>
                            <Border BackgroundColor="#80f0f6fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdae8"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Picker Title="Selecciona una categoría"
                                        ItemsSource="{Binding Categorias}"
                                        SelectedItem="{Binding Categoria}"
                                        TitleColor="#b8ccd8"
                                        TextColor="#1a2040"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        Margin="6,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Ícono -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ÍCONO (EMOJI)"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#9ab0cc"
                                   CharacterSpacing="1.5"/>

                            <!-- Sugerencias en grid glass -->
                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="💧" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🏃" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="😴" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🧘" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="📚" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Border BackgroundColor="#80f0f6fc" StrokeThickness="1" Stroke="#ccdae8"
                                        WidthRequest="44" HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🥗" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </HorizontalStackLayout>

                            <!-- Entry manual -->
                            <Border BackgroundColor="#80f0f6fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdae8"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="O escribe tu emoji aquí"
                                       Text="{Binding Icono}"
                                       MaxLength="2"
                                       PlaceholderColor="#b8ccd8"
                                       TextColor="#1a2040"
                                       FontSize="18"
                                       BackgroundColor="Transparent"
                                       Margin="6,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Separador glass -->
                        <BoxView BackgroundColor="#dde8f4" HeightRequest="1" Margin="0,2"/>

                        <!-- Botones -->
                        <Grid ColumnDefinitions="*,2*" ColumnSpacing="10" Margin="0,4,0,0">

                            <Border Grid.Column="0"
                                    BackgroundColor="#80eef4fc"
                                    StrokeThickness="1"
                                    Stroke="#ccdaea"
                                    HeightRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Button Text="Cancelar"
                                        Command="{Binding CancelarCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="#7a9ab8"
                                        FontSize="13"
                                        FontAttributes="Bold"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Text="Guardar hábito"
                                    Command="{Binding GuardarHabitoCommand}"
                                    BackgroundColor="#1a2040"
                                    TextColor="White"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    CornerRadius="14"
                                    HeightRequest="52"/>

                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
