<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.AgregarHabitoPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f2faf5">

    <Grid RowDefinitions="Auto,*">

        <!-- Header verde oscuro -->
        <Grid Grid.Row="0" BackgroundColor="#0d2918" Padding="22,54,22,28">

            <BoxView BackgroundColor="#1a4d2e"
                     WidthRequest="120" HeightRequest="120"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Rotation="30" CornerRadius="28"
                     Margin="0,-40,-30,0"/>

            <VerticalStackLayout Spacing="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BackgroundColor="#1a3d24"
                            StrokeThickness="1" Stroke="#2a5e38"
                            WidthRequest="36" HeightRequest="36"
                            VerticalOptions="Center" Margin="0,0,12,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="‹" FontSize="20" TextColor="#4ecb8d"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="NUEVO HÁBITO"
                               FontSize="9" TextColor="#4ecb8d"
                               CharacterSpacing="2" FontAttributes="Bold"/>
                        <Label Text="Personaliza tu rutina"
                               FontSize="22" FontAttributes="Bold" TextColor="#ffffff"
                               CharacterSpacing="-0.3"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Grid>

        <!-- Formulario -->
        <ScrollView Grid.Row="1" BackgroundColor="#f2faf5">
            <VerticalStackLayout Padding="20,24,20,40" Spacing="20">

                <!-- Nombre -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="NOMBRE DEL HÁBITO"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#8ab89a" CharacterSpacing="1.8"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Ej. Beber 2 litros de agua"
                               Text="{Binding Nombre}"
                               PlaceholderColor="#b8d4c0" TextColor="#0d2918"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Categoría -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="CATEGORÍA"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#8ab89a" CharacterSpacing="1.8"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Picker Title="Selecciona una categoría"
                                ItemsSource="{Binding Categorias}"
                                SelectedItem="{Binding Categoria}"
                                TitleColor="#b8d4c0" TextColor="#0d2918"
                                BackgroundColor="Transparent"
                                FontSize="14" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Frecuencia -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="FRECUENCIA"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#8ab89a" CharacterSpacing="1.8"/>
                    <HorizontalStackLayout Spacing="8">
                        <Border BackgroundColor="#0d2918" StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="Diario" FontSize="12" FontAttributes="Bold" TextColor="#4ecb8d"/>
                        </Border>
                        <Border BackgroundColor="#ffffff" StrokeThickness="1.5" Stroke="#c8e4d0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="Semanal" FontSize="12" TextColor="#6a9a7a"/>
                        </Border>
                        <Border BackgroundColor="#ffffff" StrokeThickness="1.5" Stroke="#c8e4d0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="Personalizado" FontSize="12" TextColor="#6a9a7a"/>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Ícono -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="ÍCONO (EMOJI)"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#8ab89a" CharacterSpacing="1.8"/>

                    <HorizontalStackLayout Spacing="8">
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="💧" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="🏃" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="😴" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="🧘" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="📚" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="#e0f2e8" StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Label Text="🥗" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>

                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="O escribe tu emoji aquí"
                               Text="{Binding Icono}"
                               MaxLength="2"
                               PlaceholderColor="#b8d4c0" TextColor="#0d2918"
                               FontSize="20" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <BoxView BackgroundColor="#d8eede" HeightRequest="1" Margin="0,4"/>

                <!-- Botones -->
                <Grid ColumnDefinitions="*,2*" ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="#e0f2e8"
                            StrokeThickness="0"
                            HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Button Text="Cancelar"
                                Command="{Binding CancelarCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#3a7a52"
                                FontSize="13" FontAttributes="Bold"/>
                    </Border>

                    <Button Grid.Column="1"
                            Text="Guardar hábito"
                            Command="{Binding GuardarHabitoCommand}"
                            BackgroundColor="#0d2918"
                            TextColor="#4ecb8d"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="16"
                            HeightRequest="54"/>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
