<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.BienvenidaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="260,*">

        <!-- Header compacto con blobs ilustrativos -->
        <Grid Grid.Row="0">

            <!-- Fondo degradado suave -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#e8f0ff" Offset="0.0"/>
                    <GradientStop Color="#dff0ea" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Blobs decorativos -->
            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="150"
                     HeightRequest="150"
                     Fill="#99c8deff"
                     Margin="0,-30,-30,0"/>

            <Ellipse HorizontalOptions="Start"
                     VerticalOptions="End"
                     WidthRequest="100"
                     HeightRequest="100"
                     Fill="#99c8f0dd"
                     Margin="-20,0,0,20"/>

            <Ellipse HorizontalOptions="Center"
                     VerticalOptions="Center"
                     WidthRequest="80"
                     HeightRequest="80"
                     Fill="#66ffffff"
                     Margin="60,-40,0,0"/>

            <!-- Contenido del header -->
            <VerticalStackLayout VerticalOptions="End"
                                 Padding="28,0,28,32"
                                 Spacing="10">

                <!-- Logo glass pill -->
                <Border BackgroundColor="#99ffffff"
                        StrokeThickness="1"
                        Stroke="#80d0e4f4"
                        HorizontalOptions="Start"
                        Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🌿" FontSize="18" VerticalOptions="Center"/>
                        <Label Text="Hábitos Saludables"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1a2c3d"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <Label Text="Empieza hoy,&#10;transforma mañana."
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#1a2c3d"
                       LineHeight="1.2"/>

                <Label Text="Construye hábitos que duran toda la vida."
                       FontSize="12"
                       TextColor="#6a8ca4"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Cuerpo con card glass -->
        <ScrollView Grid.Row="1" BackgroundColor="#f0f4f8">
            <VerticalStackLayout Padding="20,24,20,40" Spacing="14">

                <!-- Card glass con botones -->
                <Border BackgroundColor="#CCffffff"
                        StrokeThickness="1"
                        Stroke="#80e0eaf4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="20,22" Spacing="12">

                        <Label Text="¿Qué deseas hacer?"
                               FontSize="11"
                               TextColor="#9bb0c4"
                               HorizontalTextAlignment="Center"/>

                        <Button Text="Registrarse"
                                x:Name="RegistroBtn"
                                Clicked="OnRegisterClicked"
                                BackgroundColor="#1a2c3d"
                                TextColor="#ffffff"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                HeightRequest="52"/>

                        <Border BackgroundColor="#80f4f8fc"
                                StrokeThickness="1"
                                Stroke="#ccd8e8"
                                HeightRequest="52">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Button Text="Iniciar sesión"
                                    x:Name="LoginBtn"
                                    Clicked="OnLoginClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="#4a6a84"
                                    FontSize="14"
                                    FontAttributes="Bold"/>
                        </Border>

                        <!-- Separador -->
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="10"
                                               Margin="0,4">
                            <BoxView BackgroundColor="#dde8f0"
                                     HeightRequest="1"
                                     WidthRequest="50"
                                     VerticalOptions="Center"/>
                            <Label Text="o continúa con"
                                   FontSize="11"
                                   TextColor="#b0c4d4"
                                   VerticalOptions="Center"/>
                            <BoxView BackgroundColor="#dde8f0"
                                     HeightRequest="1"
                                     WidthRequest="50"
                                     VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label Text="v 1.0.0"
                               FontSize="10"
                               TextColor="#c4d4e0"
                               HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
