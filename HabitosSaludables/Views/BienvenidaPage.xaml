<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.BienvenidaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f2faf5">

    <Grid RowDefinitions="*,Auto">

        <!-- Zona superior ilustrada -->
        <Grid Grid.Row="0" BackgroundColor="#f2faf5">

            <!-- Bloque verde oscuro como acento superior -->
            <BoxView BackgroundColor="#0d2918"
                     HeightRequest="6"
                     VerticalOptions="Start"
                     HorizontalOptions="Fill"/>

            <!-- Forma decorativa esquina derecha -->
            <BoxView BackgroundColor="#e0f2e8"
                     WidthRequest="180"
                     HeightRequest="180"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Rotation="30"
                     Margin="0,-40,-50,0"
                     CornerRadius="32"/>

            <!-- Círculo decorativo izquierda -->
            <Ellipse WidthRequest="100"
                     HeightRequest="100"
                     Fill="#d0edda"
                     HorizontalOptions="Start"
                     VerticalOptions="End"
                     Margin="-20,0,0,60"/>

            <VerticalStackLayout VerticalOptions="Center"
                                 Padding="32,0,32,0"
                                 Spacing="16">

                <!-- Badge app -->
                <Border BackgroundColor="#e0f2e8"
                        StrokeThickness="0"
                        HorizontalOptions="Start"
                        Padding="12,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="🌿" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="Hábitos Saludables"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#1a4d2e"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <Label Text="Mejor tú,&#10;cada día."
                       FontSize="38"
                       FontAttributes="Bold"
                       TextColor="#0d2918"
                       LineHeight="1.1"
                       CharacterSpacing="-0.5"/>

                <Label Text="Construye rutinas que transforman tu vida con hábitos simples y constantes."
                       FontSize="14"
                       TextColor="#5a8a6a"
                       LineHeight="1.5"/>

                <!-- Stat pills -->
                <HorizontalStackLayout Spacing="10" Margin="0,8,0,0">
                    <Border BackgroundColor="#e0f2e8" StrokeThickness="0" Padding="12,7">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="✦  100% gratis"
                               FontSize="11" FontAttributes="Bold" TextColor="#1a4d2e"/>
                    </Border>
                    <Border BackgroundColor="#e0f2e8" StrokeThickness="0" Padding="12,7">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Sin anuncios"
                               FontSize="11" FontAttributes="Bold" TextColor="#1a4d2e"/>
                    </Border>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Grid>

        <!-- Botones inferiores -->
        <VerticalStackLayout Grid.Row="1"
                             BackgroundColor="#f2faf5"
                             Padding="24,16,24,52"
                             Spacing="12">

            <Button Text="Comenzar ahora"
                    x:Name="RegistroBtn"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#0d2918"
                    TextColor="#4ecb8d"
                    FontSize="15"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    HeightRequest="56"/>

            <Border BackgroundColor="Transparent"
                    StrokeThickness="1.5"
                    Stroke="#c0dfc8"
                    HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Button Text="Ya tengo cuenta"
                        x:Name="LoginBtn"
                        Clicked="OnLoginClicked"
                        BackgroundColor="Transparent"
                        TextColor="#2a6644"
                        FontSize="14"
                        FontAttributes="Bold"/>
            </Border>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
