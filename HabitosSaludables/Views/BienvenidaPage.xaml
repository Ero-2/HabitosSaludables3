<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.BienvenidaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f9f4ef">

    <Grid RowDefinitions="220,*">

        <!-- Hero orgánico oscuro con formas blob -->
        <Grid Grid.Row="0" BackgroundColor="#2c2416">

            <!-- Blob decorativo grande (esquina superior derecha) -->
            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="140"
                     HeightRequest="140"
                     Fill="#4a3826"
                     Margin="0,-30,-20,0"/>

            <!-- Blob pequeño acento verde (esquina inferior izquierda) -->
            <Ellipse HorizontalOptions="Start"
                     VerticalOptions="End"
                     WidthRequest="70"
                     HeightRequest="70"
                     Fill="#6b8f4f"
                     Opacity="0.4"
                     Margin="20,0,0,15"/>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Start"
                                 Spacing="10"
                                 Padding="28,0,28,0">

                <!-- Ícono con fondo verde bosque -->
                <Border BackgroundColor="#6b8f4f"
                        StrokeThickness="0"
                        HorizontalOptions="Start"
                        WidthRequest="52"
                        HeightRequest="52">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="🌿"
                           FontSize="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Título serif elegante -->
                <Label Text="Bienvenido&#10;de vuelta"
                       FontFamily="PlayfairDisplay"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#f5ede2"
                       LineHeight="1.15"/>

                <Label Text="EMPIEZA TU CAMINO HOY"
                       FontSize="10"
                       TextColor="#9b8468"
                       CharacterSpacing="1.8"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Cuerpo inferior cálido -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="28,32,28,32"
                             Spacing="14"
                             VerticalOptions="Start">

            <Label Text="¿Qué deseas hacer?"
                   FontSize="12"
                   TextColor="#b0a090"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,2"/>

            <!-- Botón primario redondeado (cápsula) -->
            <Button Text="Registrarse"
                    x:Name="RegistroBtn"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#2c2416"
                    TextColor="#f5ede2"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="50"
                    HeightRequest="52"/>

            <!-- Botón outline suave -->
            <Border BackgroundColor="Transparent"
                    StrokeThickness="1.5"
                    Stroke="#d4c9bc"
                    HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>
                <Button Text="Iniciar sesión"
                        x:Name="LoginBtn"
                        Clicked="OnLoginClicked"
                        BackgroundColor="Transparent"
                        TextColor="#2c2416"
                        FontSize="14"
                        FontAttributes="Bold"/>
            </Border>

            <!-- Separador con texto -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="10"
                                   Margin="0,6">
                <BoxView BackgroundColor="#e8e0d4"
                         HeightRequest="1"
                         WidthRequest="55"
                         VerticalOptions="Center"/>
                <Label Text="o continúa con"
                       FontSize="11"
                       TextColor="#c5b9aa"
                       VerticalOptions="Center"/>
                <BoxView BackgroundColor="#e8e0d4"
                         HeightRequest="1"
                         WidthRequest="55"
                         VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Versión -->
            <Label Text="v 1.0.0"
                   FontSize="10"
                   TextColor="#d0c8bc"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0"/>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
