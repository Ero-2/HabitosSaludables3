<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:HabitosSaludables.ViewModels"
             x:Class="HabitosSaludables.Views.MisHabitosPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="Auto,*">

        <!-- Header compacto con blobs -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#e8f0ff" Offset="0.0"/>
                    <GradientStop Color="#eef4ff" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="130"
                     HeightRequest="130"
                     Fill="#66c4d4ff"
                     Margin="0,-30,-20,0"/>

            <Ellipse HorizontalOptions="Start"
                     VerticalOptions="End"
                     WidthRequest="70"
                     HeightRequest="70"
                     Fill="#66b8c8ee"
                     Margin="30,0,0,10"/>

            <Grid Padding="22,52,22,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="COLECCIÓN"
                           FontSize="9"
                           TextColor="#8aaccc"
                           CharacterSpacing="2"
                           FontAttributes="Bold"/>
                    <Label Text="Mis Hábitos"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#1a2040"/>
                </VerticalStackLayout>

                <!-- Botón agregar glass -->
                <Border Grid.Column="1"
                        BackgroundColor="#1a2040"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        Padding="14,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="+ Nuevo"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#ffffff"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AgregarNuevoHabitoCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Grid>

        <!-- Lista con RefreshView -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     Command="{Binding LoadHabitosCommand}"
                     BackgroundColor="#f0f4f8">

            <CollectionView ItemsSource="{Binding Habitos}" BackgroundColor="Transparent">
                <CollectionView.Header>
                    <BoxView HeightRequest="14" BackgroundColor="Transparent"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <!-- Card glass por hábito -->
                        <Border Margin="18,0,18,10"
                                BackgroundColor="#CCffffff"
                                StrokeThickness="1"
                                Stroke="#80dce8f8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid Padding="16,14"
                                  ColumnDefinitions="44,*,36,36"
                                  ColumnSpacing="4">

                                <!-- Icono con fondo glass -->
                                <Border Grid.Column="0"
                                        BackgroundColor="#80eef4fc"
                                        StrokeThickness="1"
                                        Stroke="#ccdaea"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Icono}"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>

                                <!-- Nombre + racha -->
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Spacing="3"
                                                     Margin="8,0">
                                    <Label Text="{Binding Nombre}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1a2040"/>
                                    <Label Text="{Binding RachaActual, StringFormat='Racha: {0} días'}"
                                           FontSize="10"
                                           TextColor="#9ab8d0"/>
                                </VerticalStackLayout>

                                <!-- Check glass -->
                                <Border Grid.Column="2"
                                        BackgroundColor="{Binding CompletadoHoy, Converter={StaticResource BoolToColorConverter}}"
                                        StrokeThickness="1"
                                        Stroke="#ccdaea"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Button BackgroundColor="Transparent"
                                            TextColor="{Binding CompletadoHoy, Converter={StaticResource BoolToCheckColorConverter}}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            Text="✓"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MisHabitosViewModel}}, Path=ToggleCompletadoCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding CompletadoHoy, Converter={StaticResource InverseBoolConverter}}"
                                            Padding="0"
                                            WidthRequest="34"
                                            HeightRequest="34"/>
                                </Border>

                                <!-- Eliminar -->
                                <Button Grid.Column="3"
                                        Text="🗑"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MisHabitosViewModel}}, Path=EliminarHabitoCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#c0d0e0"
                                        FontSize="15"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        Padding="0"
                                        VerticalOptions="Center"/>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </RefreshView>

    </Grid>
</ContentPage>
