<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f4f8">

    <AbsoluteLayout>

        <!-- Blobs decorativos de fondo para efecto glassmorphism -->
        <Ellipse AbsoluteLayout.LayoutBounds="0.15, 0.18, 260, 260"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Fill="#CCd4e8ff"
                 Opacity="0.7"/>

        <Ellipse AbsoluteLayout.LayoutBounds="0.85, 0.72, 220, 220"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Fill="#CCdcf5e8"
                 Opacity="0.6"/>

        <Ellipse AbsoluteLayout.LayoutBounds="0.5, 0.55, 180, 180"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Fill="#CCf0e8ff"
                 Opacity="0.4"/>

        <!-- Card glassmorphism central -->
        <Border AbsoluteLayout.LayoutBounds="0.5, 0.5, 280, 340"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                BackgroundColor="#CCffffff"
                StrokeThickness="1"
                Stroke="#80ffffff">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 Padding="28">

                <!-- Icono con fondo glass -->
                <Border BackgroundColor="#99ffffff"
                        StrokeThickness="1"
                        Stroke="#80e0e8f0"
                        HorizontalOptions="Center"
                        WidthRequest="80"
                        HeightRequest="80">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="🌿"
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="Hábitos"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#1a2236"
                       HorizontalTextAlignment="Center"
                       Margin="0,6,0,-6"/>

                <Label Text="Saludables"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#5a7a99"
                       HorizontalTextAlignment="Center"/>

                <Label Text="TU BIENESTAR DIARIO"
                       FontSize="10"
                       TextColor="#9bb0c4"
                       CharacterSpacing="2.5"
                       HorizontalTextAlignment="Center"
                       Margin="0,6,0,0"/>

                <!-- Puntos de carga -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="8"
                                       Margin="0,12,0,0">
                    <BoxView BackgroundColor="#1a2236"
                             WidthRequest="22"
                             HeightRequest="5"
                             CornerRadius="3"/>
                    <BoxView BackgroundColor="#ccd8e4"
                             WidthRequest="5"
                             HeightRequest="5"
                             CornerRadius="3"/>
                    <BoxView BackgroundColor="#ccd8e4"
                             WidthRequest="5"
                             HeightRequest="5"
                             CornerRadius="3"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>

    </AbsoluteLayout>
</ContentPage>
