<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0d2918">

    <AbsoluteLayout>

        <!-- Forma geométrica superior derecha -->
        <BoxView AbsoluteLayout.LayoutBounds="1, 0, 200, 200"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 BackgroundColor="#1a4d2e"
                 Rotation="45"
                 Margin="60,-60,0,0"/>

        <!-- Círculo decorativo -->
        <Ellipse AbsoluteLayout.LayoutBounds="0.05, 0.78, 140, 140"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Fill="#1a3d24"
                 Opacity="0.8"/>

        <Ellipse AbsoluteLayout.LayoutBounds="0.9, 0.6, 80, 80"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Fill="#2a5e3a"
                 Opacity="0.5"/>

        <!-- Contenido central -->
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.48, 1, AutoSize"
                             AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                             HorizontalOptions="Center"
                             Spacing="0"
                             Padding="40,0">

            <!-- Ícono pill moderno -->
            <Border BackgroundColor="#1e5c34"
                    StrokeThickness="1"
                    Stroke="#2e7a48"
                    HorizontalOptions="Center"
                    WidthRequest="80"
                    HeightRequest="80"
                    Margin="0,0,0,28">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>
                <Label Text="🌿"
                       FontSize="38"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="Hábitos"
                   FontSize="44"
                   FontAttributes="Bold"
                   TextColor="#ffffff"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="-0.5"
                   LineHeight="1"
                   Margin="0,0,0,-6"/>

            <Label Text="Saludables"
                   FontSize="44"
                   FontAttributes="Bold"
                   TextColor="#4ecb8d"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="-0.5"
                   LineHeight="1"
                   Margin="0,0,0,20"/>

            <!-- Tagline pill -->
            <Border BackgroundColor="#1a3d24"
                    StrokeThickness="1"
                    Stroke="#2a5e38"
                    HorizontalOptions="Center"
                    Padding="18,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Label Text="TU BIENESTAR · CADA DÍA"
                       FontSize="10"
                       TextColor="#4ecb8d"
                       CharacterSpacing="2"/>
            </Border>

        </VerticalStackLayout>

        <!-- Indicadores -->
        <HorizontalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.9, AutoSize, AutoSize"
                               AbsoluteLayout.LayoutFlags="PositionProportional"
                               Spacing="8">
            <BoxView BackgroundColor="#4ecb8d"
                     WidthRequest="24" HeightRequest="5"
                     CornerRadius="3" VerticalOptions="Center"/>
            <BoxView BackgroundColor="#1e4a2c"
                     WidthRequest="5" HeightRequest="5"
                     CornerRadius="3" VerticalOptions="Center"/>
            <BoxView BackgroundColor="#1e4a2c"
                     WidthRequest="5" HeightRequest="5"
                     CornerRadius="3" VerticalOptions="Center"/>
        </HorizontalStackLayout>

    </AbsoluteLayout>
</ContentPage>
