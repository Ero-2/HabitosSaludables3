<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:HabitosSaludables.ViewModels"
             x:Class="HabitosSaludables.Views.HomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f2faf5">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <Grid Grid.Row="0" BackgroundColor="#0d2918">

            <Ellipse HorizontalOptions="End" VerticalOptions="Start"
                     WidthRequest="120" HeightRequest="120"
                     Fill="#1a4d2e" Margin="0,-20,-20,0"/>
            <Ellipse HorizontalOptions="Start" VerticalOptions="End"
                     WidthRequest="60" HeightRequest="60"
                     Fill="#1e3d28" Opacity="0.5" Margin="20,0,0,-10"/>

            <Grid Padding="22,52,22,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="BUENOS DÍAS"
                           FontSize="10" TextColor="#4ecb8d"
                           CharacterSpacing="2.2" FontAttributes="Bold"/>
                    <Label Text="{Binding NombreUsuario}"
                           FontSize="24" FontAttributes="Bold" TextColor="#ffffff"
                           CharacterSpacing="-0.3"/>
                    <Label Text="¿Listo para tus hábitos de hoy?"
                           FontSize="11" TextColor="#4a7a58"/>
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#1a4d2e"
                        StrokeThickness="2"
                        Stroke="#4ecb8d"
                        WidthRequest="46"
                        HeightRequest="46"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="23"/>
                    </Border.StrokeShape>
                    <Label Text="C"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#4ecb8d"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#1e3d28"
                        StrokeThickness="0"
                        WidthRequest="46"
                        HeightRequest="46"
                        VerticalOptions="Center"
                        Margin="12,0,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="23"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="🚪"
                           FontSize="18"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Padding="18,0,18,12" Margin="0,-22,0,0">
            <Border BackgroundColor="#1a4d2e"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Grid Padding="18,16" ColumnDefinitions="*,*,*,Auto" ColumnSpacing="0">

                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="6">
                        <Grid WidthRequest="54" HeightRequest="54" HorizontalOptions="Center">
                            <Ellipse WidthRequest="54" HeightRequest="54"
                                     Stroke="#0d2918" StrokeThickness="5" Fill="Transparent"/>
                            <Ellipse WidthRequest="44" HeightRequest="44"
                                     Stroke="#4ecb8d" StrokeThickness="4.5" Fill="Transparent"
                                     HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Label Text="{Binding HabitosCompletados, StringFormat='{0}/3'}"
                                   FontSize="10" FontAttributes="Bold" TextColor="#ffffff"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <Label Text="Hábitos" FontSize="9" TextColor="#4a7a58" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="6">
                        <Grid WidthRequest="54" HeightRequest="54" HorizontalOptions="Center">
                            <Ellipse WidthRequest="54" HeightRequest="54"
                                     Stroke="#0d2918" StrokeThickness="5" Fill="Transparent"/>
                            <Ellipse WidthRequest="44" HeightRequest="44"
                                     Stroke="#2e8a54" StrokeThickness="4.5" Fill="Transparent"
                                     HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Label Text="8h"
                                   FontSize="11" FontAttributes="Bold" TextColor="#ffffff"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <Label Text="Sueño" FontSize="9" TextColor="#4a7a58" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="6">
                        <Grid WidthRequest="54" HeightRequest="54" HorizontalOptions="Center">
                            <Ellipse WidthRequest="54" HeightRequest="54"
                                     Stroke="#0d2918" StrokeThickness="5" Fill="Transparent"/>
                            <Ellipse WidthRequest="44" HeightRequest="44"
                                     Stroke="#1e6640" StrokeThickness="4.5" Fill="Transparent"
                                     HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Label Text="1.2L"
                                   FontSize="10" FontAttributes="Bold" TextColor="#ffffff"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <Label Text="Agua" FontSize="9" TextColor="#4a7a58" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <Border Grid.Column="3"
                            BackgroundColor="#0d2918"
                            StrokeThickness="1" Stroke="#2a5e38"
                            VerticalOptions="Center"
                            Padding="10,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                            <Label Text="🔥" FontSize="16" HorizontalOptions="Center"/>
                            <Label Text="{Binding RachaTotal}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#4ecb8d" HorizontalOptions="Center" LineHeight="1"/>
                            <Label Text="días" FontSize="8" TextColor="#4a7a58" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2" BackgroundColor="#f2faf5">
            <VerticalStackLayout Padding="18,4,18,12" Spacing="0">

                <Grid Padding="2,0,2,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Text="Hábitos de hoy"
                           FontSize="16" FontAttributes="Bold" TextColor="#0d2918"
                           CharacterSpacing="-0.2"/>
                    <Label Grid.Column="1"
                           Text="Ver todos ›"
                           FontSize="11" TextColor="#3a7a52"
                           FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>

                <CollectionView ItemsSource="{Binding HabitosPendientes}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    BackgroundColor="#ffffff"
                                    StrokeThickness="1.5"
                                    Stroke="#d8eede">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=MarcarCompletadoCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid Padding="14,14" ColumnDefinitions="46,*,36">

                                    <Border Grid.Column="0"
                                            BackgroundColor="#e0f2e8"
                                            StrokeThickness="0"
                                            WidthRequest="38" HeightRequest="38"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="11"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Icono}"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="3" Margin="10,0">
                                        <Label Text="{Binding Nombre}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#0d2918"/>
                                        <Label Text="{Binding RachaActual, StringFormat='🔥 {0} días seguidos'}"
                                               FontSize="10" TextColor="#8ab89a"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Column="2"
                                            BackgroundColor="#e0f2e8"
                                            StrokeThickness="1.5"
                                            Stroke="#b0d8bc"
                                            WidthRequest="32" HeightRequest="32"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Button BackgroundColor="Transparent"
                                                TextColor="#3a7a52"
                                                FontSize="14" FontAttributes="Bold"
                                                Text="✓"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=MarcarCompletadoCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="0"
                                                WidthRequest="32" HeightRequest="32"/>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="🎉  ¡Todos los hábitos completados!"
                       IsVisible="{Binding HabitosPendientes.Count, Converter={StaticResource CountToBoolConverter}}"
                       FontSize="13" TextColor="#3a7a52" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,14"/>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="3"
                BackgroundColor="#0d2918"
                StrokeThickness="0"
                Margin="16,0,16,24">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*,*"
                  Padding="8,10"
                  ColumnSpacing="4">

                <Border Grid.Column="0"
                        BackgroundColor="#4ecb8d"
                        StrokeThickness="0"
                        Padding="0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegistrarActividadClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="⭐" FontSize="16" HorizontalOptions="Center"/>
                        <Label Text="Inicio" FontSize="9" FontAttributes="Bold"
                               TextColor="#0d2918" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="0,10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVerEstadisticasClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="📊" FontSize="16" HorizontalOptions="Center"/>
                        <Label Text="Stats" FontSize="9" TextColor="#4a7a58" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="0,10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMisHabitosClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="📋" FontSize="16" HorizontalOptions="Center"/>
                        <Label Text="Hábitos" FontSize="9" TextColor="#4a7a58" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="3"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="0,10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPerfilClicked"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="👤" FontSize="16" HorizontalOptions="Center"/>
                        <Label Text="Perfil" FontSize="9" TextColor="#4a7a58" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Border>

    </Grid>
</ContentPage>