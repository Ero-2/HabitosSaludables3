<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.RegistroPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f2faf5">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#0d2918" Padding="24,54,24,32">

            <BoxView BackgroundColor="#1a4d2e"
                     WidthRequest="160" HeightRequest="160"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Rotation="20" CornerRadius="30"
                     Margin="0,-60,-40,0"/>

            <Ellipse WidthRequest="80" HeightRequest="80"
                     Fill="#2a6644" Opacity="0.35"
                     HorizontalOptions="Start" VerticalOptions="End"
                     Margin="10,0,0,10"/>

            <VerticalStackLayout Spacing="10">

                <Border BackgroundColor="#1a3d24"
                        StrokeThickness="1" Stroke="#2a5e38"
                        WidthRequest="36" HeightRequest="36"
                        HorizontalOptions="Start" Margin="0,0,0,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Label Text="&#8249;" FontSize="20" TextColor="#4ecb8d"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Border BackgroundColor="#1a4d2e"
                        StrokeThickness="1" Stroke="#2e7a48"
                        HorizontalOptions="Start" Padding="10,7">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#127807;" FontSize="16" VerticalOptions="Center"/>
                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                            <Label Text="Habitos Saludables"
                                   FontSize="12" FontAttributes="Bold" TextColor="#4ecb8d"/>
                            <Label Text="Tu bienestar diario"
                                   FontSize="9" TextColor="#3a7a52"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Label Text="Crea tu cuenta"
                       FontSize="30" FontAttributes="Bold"
                       TextColor="#ffffff" CharacterSpacing="-0.3"
                       Margin="0,6,0,0"/>

                <Label Text="Gratis - Rapido - Sin complicaciones"
                       FontSize="12" TextColor="#4a7a58"/>

            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" BackgroundColor="#f2faf5">
            <VerticalStackLayout Padding="24,28,24,40" Spacing="18">

                <VerticalStackLayout Spacing="8">
                    <Label Text="NOMBRE COMPLETO"
                           FontSize="10" TextColor="#8ab89a"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="nombreEntry"
                               Placeholder="Ej. Carlos Garcia"
                               Text="{Binding Nombre}"
                               PlaceholderColor="#b8d4c0" TextColor="#0d2918"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="CORREO ELECTRONICO"
                           FontSize="10" TextColor="#8ab89a"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="emailEntry"
                               Placeholder="tu@correo.com"
                               Keyboard="Email" Text="{Binding Email}"
                               PlaceholderColor="#b8d4c0" TextColor="#0d2918"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="CONTRASENA"
                           FontSize="10" TextColor="#8ab89a"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#c8e4d0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="contrasenaEntry"
                               Placeholder="Minimo 8 caracteres"
                               IsPassword="True" Text="{Binding Contrasena}"
                               PlaceholderColor="#b8d4c0" TextColor="#0d2918"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <Border BackgroundColor="#e0f2e8" StrokeThickness="0" Padding="14,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="&#128274;" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="Tu informacion esta segura y nunca sera compartida."
                               FontSize="11" TextColor="#3a7a52"
                               VerticalOptions="Center" LineHeight="1.4"/>
                    </HorizontalStackLayout>
                </Border>

                <Button Text="Crear cuenta"
                        x:Name="RegistrarBtn"
                        Clicked="OnRegisterClicked"
                        BackgroundColor="#0d2918"
                        TextColor="#4ecb8d"
                        FontSize="15" FontAttributes="Bold"
                        CornerRadius="16" HeightRequest="56"
                        Margin="0,4,0,0"/>

                <Label x:Name="LoginBtn"
                       FontSize="13" HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Ya tienes cuenta? " TextColor="#8ab89a" FontSize="13"/>
                            <Span Text="Inicia sesion" TextColor="#0d2918" FontSize="13" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginClicked"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
